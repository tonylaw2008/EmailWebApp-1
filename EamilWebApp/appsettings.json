{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // 確保開發環境也有完整的 Kestrel 配置
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8088" // 注意部署時候 改為 http://0.0.0.0:8088 
      },
      "Https": {
        "Url": "https://0.0.0.0:8089", // 注意部署時候 localhost 改為 https://0.0.0.0:8089 
        "Certificate": {
          "Path": "./Cer/xguard.hk.pfx",
          "Password": "123456"
        }
      }
    },
    "Limits": {
      "MaxRequestHeadersTotalSize": 32768
    }
  },

  "AllowedHosts": "*",

  "SUPPORT_HTTP_REQUEST": true,

  // 身份驗證用戶 才允許通過發郵件 只允許Bearer 方式
  // 提供 MainComId 或 ShopId 來識別不同的系統用戶  二選一即可，優先使用 MainComId 來識別用戶。
  // 如果既然提供給 DGX HRMS 和 IshopX 兩個系統用戶的身份驗證信息，則 MainComId 和 ShopId 同時填入。
  // 如果 EamilWebApp 獨立使用 ， 則 自定義一個 MainComID 
  // 如果提供給IshopX 則使用 ShopId  來識別用戶
  // authenticationCode 是自己自定義的，一般是一串密碼MD5。
  "AuthenticUser": [
    {
      "mainComId": "6000014",
      "shopId": "sh0006",
      "userName": "XGuard1",
      "authenticationCode": "0f18abd25e9519cd69b0b4848fa393fd",
      "authenticMethods": "Bearer"
    },
    {
      "mainComId": "6000019",
      "shopId": "",
      "userName": "XGuard2",
      "authenticationCode": "111111111111111111111111111111",
      "authenticMethods": "Bearer"
    }
  ],

  "MailToDefault": "mcessol2000@gmail.com", //默認發送目標郵箱地址（）

  // 優先使用本地自定義的配置：例如 ./Config/SenderEmailAccountList_6000014.json
  "senderEmailAccountList": [
    {
      "senderOfCompany": "xguard.hk",
      "mailTool": 2, // SYSTEM_NET_MAIL_SMTP = 0,MAIL_KIT_SMTP = 1,QQ_SMTP = 2,OUTLOOK_SMTP = 3
      "enableSSL": false, // 端口 587 用 TSL，不启用 SSL
      "enableTSL": true, // QQ 587 端口必须启用 TSL
      "enablePasswordAuthentication": true,
      "senderServerHost": "smtp.qq.com", // QQ 发送服务器
      "senderServerHostPort": 587, // QQ SMTP 支持 465/587，这里用 587
      "fromMailAddress": "service1@xguard.hk", // 发件邮箱
      "fromMailDisplayName": "Service Center Of Xguard",
      "senderUserName": "service1@xguard.hk", // QQ 要求：必须填完整邮箱
      "senderUserPassword": "papfcbaviecsbghd", // 你提供的 QQ 授权码（不是密码）
      "Remarks": "[Tool:MailKit] [QQ SMTP] [TSL=587] 已按 QQ 邮箱 SMTP 官方规则配置，使用授权码登录。"
    },
    {
      "senderOfCompany": "xguard.hk",
      "mailTool": 1, // SYSTEM_NET_MAIL_SMTP = 0,MAIL_KIT_SMTP = 1,QQ_SMTP = 2,OUTLOOK_SMTP = 3
      "enableSSL": false, // SSL證書發送，senderServerHostPort=465
      "enableTSL": true, // TSL 發送，senderServerHostPort=587
      "enablePasswordAuthentication": true,
      "senderServerHost": "smtp-relay.brevo.com",
      "senderServerHostPort": 587, //SSL 默認PORT465 | TLS 默認PORT 587
      "fromMailAddress": "service1@xguard.hk",
      "fromMailDisplayName": "Service Center Of Xguard",
      "senderUserName": "955ced001@smtp-brevo.com",
      "senderUserPassword": "xsmtpsib-dfacfc38a44a9b6b991e48566e80c7f81f8d6ad061cad3e4066d61d214a3a7c3-5nPqsJIq7ntoeSHX", // 从 Brevo 控制台获取的 SMTP KEY 密钥
      "Remarks": "[mailTool:System.Net.Mail.SmtpClient=0; MailKit.Net.Smtp.SmtpClient=1] [StartTLS=587;SSL=465] This is the brevo.com email account used for sending emails from XGuard."
    }
  ]
}
