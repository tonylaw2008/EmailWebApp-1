@{
    ViewData["Title"] = "Home Page - Email Web App";
}
@model IList<MailEnhanceService.AuthenticUserModel>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Select a Maincom</h3>
                </div>
                <div class="card-body">
                    <p class="lead">Please select a MainCom to start sending emails.：</p>
                    <div class="list-group">
                        @foreach (var user in Model)
                        {
                            <a href="@Url.Action("Authorize", "Home", new { mainComId = user.MainComId })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@user.UserName</strong>
                                    <br />
                                    <small class="text-muted" data-bs-toggle="tooltip"
                                           data-bs-placement="top" title="MainComId may be consider as oganation/user/shop/app/utilities">MainComId：@user.MainComId</small>
                                </div>
                                <span class="bg-primary rounded-1 m-1 p-1 text-white text-nowrap"><i class="fa-solid fa-envelope me-lg-1"></i>Send Email <i class="fa-solid fa-angle-right ms-lg-1"></i></span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>